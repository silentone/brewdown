---
import BaseLayout from '../layouts/BaseLayout.astro';
import BrewdownApp from '../components/BrewdownApp.svelte';
---

<BaseLayout>
  <section class="mx-auto max-w-container px-[var(--gutter)] pb-8 pt-10 md:pb-10 md:pt-12">
    <p class="font-mono text-xs uppercase tracking-wide text-ink-3">
      Calculator · Home brewing cost
    </p>
    <h1 class="mt-2 max-w-2xl font-display text-4xl font-bold tracking-tight text-ink md:text-5xl">
      Compare the true cost of how you brew coffee
    </h1>
    <p class="mt-3 max-w-xl text-lg text-ink-2">
      Pods vs bean-to-cup, drip, pour-over, and more. See when lines cross and savings add up over time.
    </p>
  </section>

  <BrewdownApp client:load />
</BaseLayout>
