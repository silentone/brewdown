---
import BrewdownApp from './BrewdownApp.svelte';
import { showAffiliates, type SiteFlavor } from '../lib/site-flavor';

interface Props {
  flavor: SiteFlavor;
}

const { flavor } = Astro.props;
---

<div class="relative">
  <div class="calculator-page-bg" aria-hidden="true"></div>

  <img
    src="/illustrations/hero-coffee.svg"
    alt=""
    aria-hidden="true"
    class="pointer-events-none fixed right-0 top-0 z-[1] w-[60vw] translate-x-[18%] -translate-y-[15%] select-none opacity-[0.22]"
  />

  <div class="hero-steam-layer" aria-hidden="true">
    <span class="hero-steam-plume"></span>
    <span class="hero-steam-plume"></span>
    <span class="hero-steam-plume"></span>
    <span class="hero-steam-plume"></span>
    <span class="hero-steam-plume"></span>
    <span class="hero-steam-plume"></span>
    <span class="hero-steam-plume"></span>
  </div>

  <div class="relative z-10">
    <section class="mx-auto max-w-container px-[var(--gutter)] pb-8 pt-6 md:pb-10 md:pt-8">
      <h1
        class="mt-2 max-w-3xl font-display text-[clamp(2.35rem,5.1vw,4.6rem)] font-extrabold leading-[0.95] tracking-[-0.028em] text-ink [text-wrap:balance]"
      >
        Compare the true cost of how you brew coffee
      </h1>
      <p class="mt-3 max-w-xl text-lg text-ink-2">
        Pod coffee can look cheap upfront, but coffee cost over time climbs fast. Bean-to-cup machines keep one-touch convenience, make more than just espresso (americano, cappuccino, latte, and more), and deliver better coffee at a lower total cost. Test your daily coffee habits and see how costs change.
      </p>
    </section>

    <BrewdownApp client:load showAffiliates={showAffiliates(flavor)} />
  </div>
</div>
