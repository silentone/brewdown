---
const nav = [
  { href: '/', label: 'Calculator' },
  { href: '/about', label: 'About' },
  { href: '/privacy', label: 'Privacy' },
];
---

<header class="border-b border-[var(--line)] bg-paper">
  <div
    class="mx-auto flex max-w-container items-center justify-between gap-6 px-[var(--gutter)] py-5"
  >
    <a href="/" class="font-display text-xl font-bold tracking-tight text-ink">
      The Brewdown
    </a>
    <nav aria-label="Main">
      <ul class="flex flex-wrap items-center gap-6">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-sm font-medium text-ink-2 transition-colors hover:text-brand"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
